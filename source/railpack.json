{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": ["bun install --frozen-lockfile"]
    },
    "migrate": {
      "inputs": [{ "step": "install" }],
      "commands": ["bun run payload migrate:create --skip-empty", "bun run payload migrate"]
    },
    "build": {
      "inputs": [{ "step": "migrate" }],
      "commands": ["bun run build"]
    }
  },
  "deploy": {
    "startCommand": "bun run start"
  }
}
